#!/usr/bin/env bash
# talker — thin launcher: activates the project venv and runs talker.py.
set -euo pipefail

ROOT="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"

if [[ ! -f "$ROOT/.venv/bin/activate" ]]; then
    echo "talker: no venv at $ROOT/.venv — run $ROOT/setup.sh first" >&2
    exit 1
fi

# shellcheck disable=SC1091
source "$ROOT/.venv/bin/activate"
exec python "$ROOT/talker.py" "$@"
